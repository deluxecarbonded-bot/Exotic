/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "exotic",
	"compatibility_date": "2026-02-28",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},

	/**
	 * Durable Objects
	 * https://developers.cloudflare.com/durable-objects/
	 *
	 * To add a new DO:
	 * 1. Create the class in workers/ (see workers/example-do.ts)
	 * 2. Export it from workers/app.ts
	 * 3. Add binding below
	 * 4. Add migration (increment tag, add new_sqlite_classes for SQLite DOs)
	 * 5. Run `bun wrangler types` to update Env types
	 */
	// Uncomment to enable Durable Objects:
	// "durable_objects": {
	// 	"bindings": [
	// 		{ "name": "EXAMPLE_DO", "class_name": "ExampleDO" }
	// 		// { "name": "Chat", "class_name": "Chat" }
	// 		// { "name": "CHAT_SESSIONS", "class_name": "ChatSessionsDO" }
	// 	]
	// },
	// "migrations": [
	// 	{ "tag": "v1", "new_sqlite_classes": ["ExampleDO", "ChatSessionsDO", "Chat"] }
	// ],

	/**
	 * R2 Object Storage
	 * https://developers.cloudflare.com/r2/
	 *
	 * Use any bucket name — buckets are created automatically on first use.
	 * Access via env.MY_BUCKET.get(), .put(), .list(), .delete()
	 */
	// "r2_buckets": [
	// 	{ "binding": "MY_BUCKET", "bucket_name": "starter-uploads" }
	// ],

	/**
	 * Workers AI
	 * https://developers.cloudflare.com/workers-ai/
	 *
	 * Optional: declare a native AI binding for `workers-ai-provider`
	 * (`createWorkersAI({ binding: env.AI })`).
	 * In camelAI deploys, this is virtualized and rewritten to the platform AI entrypoint.
	 */
	"ai": { "binding": "AI" },

	/**
	 * Runtime variables available in loader/action context via context.cloudflare.env
	 */
	"vars": {
		"AI_VIRTUAL_MODEL": "auto",
		"VALUE_FROM_CLOUDFLARE": "Starter template running on Cloudflare",
		"SUPABASE_URL": "https://jzbpmajvncwslqdrzijr.supabase.co",
		"SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp6YnBtYWp2bmN3c2xxZHJ6aWpyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxNzg4MTcsImV4cCI6MjA5MTc1NDgxN30.gZP_ebZs_t5bfcWDBgoHtJRoOuqVYjWqC0kBUMSf8dQ",
		"SUPABASE_SERVICE_ROLE_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp6YnBtYWp2bmN3c2xxZHJ6aWpyIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjE3ODgxNywiZXhwIjoyMDkxNzU0ODE3fQ.kNWrI3eQenQvsrvqmac-BJ4r33XV7AArdZcqYXGt0zs",
		// Cloudflare Stream – required for OBS/RTMP support
		// 1. Find your Account ID at dash.cloudflare.com (right sidebar)
		// 2. Create an API token with "Stream:Edit" permission
		"CF_ACCOUNT_ID": "5957109bb6c6b260747df55ba9d67dd2",
		"CF_STREAM_TOKEN": ""
	},

	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
	 */
	// "placement": {  "mode": "smart" }

	/**
	 * Static Assets
	 * https://developers.cloudflare.com/workers/static-assets/binding/
	 */
	"assets": { "directory": "./public/", "binding": "ASSETS" },

	/**
	 * Worker Loaders (required for @cloudflare/codemode)
	 * Enables DynamicWorkerExecutor to run LLM-generated code in ephemeral isolates.
	 */
	"worker_loaders": [{ "binding": "LOADER" }],

	/**
	 * Service bindings
	 * - DATA_PROXY: locally binds to LocalDataProxyService; virtualized on camelAI deploy
	 */
	"services": [
		{ "binding": "DATA_PROXY", "service": "exotic", "entrypoint": "LocalDataProxyService" }
	]
}
